# 공공데이터포털 인증키 (디코딩 키). data.go.kr 마이페이지에서 발급.
DATA_GO_KR_SERVICE_KEY=

# true: 목업 데이터로 동작 (기본) / false: 실제 오픈API 호출
USE_MOCK=true

# 오픈API 엔드포인트 — 활용신청 승인 후 각 데이터의 기술문서에 적힌
# "요청주소(End Point)"를 그대로 넣으세요. 비워두면 코드의 기본 주소를
# 사용하며, 주소가 다르면 호출 실패 후 목업으로 자동 대체됩니다.
# 국민체력100 체력인증센터 측정결과 정보 (15108938)
KSPO_MEASUREMENT_API_URL=
# 국민체력100 동영상 정보 (15108846)
KSPO_VIDEO_API_URL=
# 국민체력100 체력인증센터 측정건수 정보 (15114286)
KSPO_CENTER_API_URL=
